{
  "info": {
    "name": "POS & Inventory Management API",
    "description": "Complete Postman collection for the Spring Boot POS system.\n\nSetup:\n1. Set BASE_URL variable to http://localhost:8080\n2. Run 'Login' request first — the token is saved automatically\n3. All other requests use {{token}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8080" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.token) pm.collectionVariables.set('token', r.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"password123\",\n  \"role\": \"CASHIER\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📦 Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/products?page=0&size=10&sort=name",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/products/search?q=cola",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get By Barcode",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/products/barcode/BAR-001-CC500",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Product\",\n  \"barcode\": \"BAR-TEST-001\",\n  \"category\": \"Beverages\",\n  \"price\": 2.99,\n  \"taxRate\": 5.0\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/products/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Coca-Cola 500ml Updated\",\n  \"price\": 2.49\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/products/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "🏪 Sales (POS)",
      "item": [
        {
          "name": "Create Sale",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/sales",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"CASH\",\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 2 },\n    { \"productId\": 2, \"quantity\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All Sales",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/sales?page=0&size=10&sort=createdAt,desc",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Sale By ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/sales/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Refund Sale",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/sales/1/refund",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "📊 Inventory",
      "item": [
        {
          "name": "Get All Inventory",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/inventory",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Low Stock Items",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/inventory/low-stock",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Adjust Stock (Stock In)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/inventory/1/adjust",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 50,\n  \"type\": \"IN\",\n  \"note\": \"Restocked from supplier\"\n}"
            }
          }
        },
        {
          "name": "Get Alerts",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/inventory/alerts",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Resolve Alert",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/inventory/alerts/1/resolve",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "📈 Reports",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/reports/summary",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Daily Report",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/reports/daily?date=2026-04-20",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Monthly Report",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/reports/monthly?year=2026&month=4",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Inventory Report",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/reports/inventory",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Top Products",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/reports/top-products?limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
